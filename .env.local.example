# お問い合わせフォーム（Resend）設定
# 本番では .env.local にコピーして実値を設定してください（.env.local はコミットされません）。
#
# キー未設定でも開発は可能です。その場合メールは送信されず、
# 送信内容がサーバーコンソールに出力されます（dev用フォールバック）。

# Resend APIキー（https://resend.com で取得）
RESEND_API_KEY=

# 問い合わせ通知の宛先（クライアント企業の受信用アドレス）
CONTACT_EMAIL=

# 送信元アドレス（Resendで認証済みドメインのアドレス）
# 例: noreply@example.com
CONTACT_FROM=
